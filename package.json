{
  "name": "dbshow",
  "type": "module",
  "version": "0.0.10",
  "description": "A CLI tool to show database schema, support Postgres, MySQL, MariaDB, SQLite, Microsoft SQL Server, Oracle Database etc.",
  "author": "xbmlz <chenxc170016@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/xbmlz/dbshow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xbmlz/dbshow.git"
  },
  "bugs": {
    "url": "https://github.com/xbmlz/dbshow/issues"
  },
  "keywords": [
    "cli",
    "database",
    "schema",
    "mysql",
    "postgresql",
    "sqlite",
    "docs",
    "markdown",
    "word"
  ],
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "dbshow": "bin/dbshow.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "esno src/cli.ts",
    "build": "unbuild",
    "prepublishOnly": "nr build",
    "release": "bumpp && npm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@inquirer/prompts": "^2.3.1",
    "gradient-string": "^2.0.2",
    "mysql2": "^3.18.1",
    "ora": "^6.3.1",
    "oracledb": "^6.10.0",
    "pg": "^8.19.0",
    "pg-hstore": "^2.3.4",
    "quicktype-core": "^23.2.6",
    "sequelize": "^6.37.7",
    "sql-ddl-to-json-schema": "^4.1.1",
    "tedious": "^16.7.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.39.8",
    "@types/gradient-string": "^1.1.6",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20.19.34",
    "bumpp": "^9.11.1",
    "eslint": "^8.44.0",
    "esno": "^0.16.3",
    "typescript": "^5.9.3",
    "unbuild": "^1.2.1"
  },
  "eslintConfig": {
    "extends": "@antfu"
  }
}
